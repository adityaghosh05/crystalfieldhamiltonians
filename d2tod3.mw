<Group labelreference="L72" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"> Capacitance := proc(B, T)      local beta, h, Z1, Z2, Z3, lnZ1, lnZ2, lnZ3, d2lnZ;      beta := 1.0/T;      h := 1e-3; #` small step size`        #` Compute lnZ at three beta values`      lnZ1 := log(Z(beta - h, B));      lnZ2 := log(Z(beta, B));      lnZ3 := log(Z(beta + h, B));        #` Second derivative (central finite difference)`      d2lnZ := (lnZ3 - 2*lnZ2 + lnZ1) / (h^2);        return evalf(beta^2 * d2lnZ);  end proc:    #` Plot`  plot3d(      (B, T) -&gt; Capacitance(B, T),      0 .. 5, 0.1 .. 5,      axes = boxed,      labels = [&quot;B&quot;, &quot;T&quot;, &quot;Capacitance&quot;],      shading = zhue  );</Text-field>
</Input>
