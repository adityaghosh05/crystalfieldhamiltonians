<Group labelreference="L84" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Function to compute heat capacity for given 'a'
HeatCap := proc(a, T, B)
    local H, Evals, beta, Z, C;
    global sz;
    
    H := a*H2 + (1 - a)*d3;
    Evals := Eigenvalues(H, output = list);
    

    beta := 'beta';   # symbolic beta
    Z := exp(-beta*(Evals[1]-B*sz[1]))+exp(-beta*(Evals[2]-B*sz[2]))+exp(-beta*(Evals[3]-B*sz[3]))+exp(-beta*(Evals[4]-B*sz[4]))+exp(-beta*(Evals[5]-B*sz[5]))+exp(-beta*(Evals[6]-B*sz[6]));
    C := diff(diff(ln(Z), beta), beta);
    C := subs(beta = 1/T, C);
    return C;
end proc:</Text-field>
</Input>
